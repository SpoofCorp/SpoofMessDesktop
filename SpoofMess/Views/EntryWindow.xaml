<Window x:Class="SpoofMess.Views.EntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SpoofMess.Views"
        xmlns:uc="clr-namespace:SpoofMess.ViewElements"
        xmlns:vm="clr-namespace:SpoofMess.ViewModels"
        xmlns:views="clr-namespace:SpoofMess.Views"
        mc:Ignorable="d"
        Title="EntryWindow" Height="450" Width="800" Background="{DynamicResource SecondWhite}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:RegistrationViewModel}">
            <views:RegistrationView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:AuthorizationViewModel}">
            <views:AuthorizationView />
        </DataTemplate>
    </Window.Resources>
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <Border CornerRadius="10" Background="White">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="#999999" ShadowDepth="0" RenderingBias="Quality"/>
            </Border.Effect>
        </Border>
        <Border CornerRadius="10" Background="White" Padding="10 20">
            <ContentPresenter Content="{Binding ViewModel}"/>
        </Border>
    </Grid>
</Window>
