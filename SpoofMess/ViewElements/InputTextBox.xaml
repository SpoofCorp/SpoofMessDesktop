<UserControl x:Class="SpoofMess.ViewElements.InputTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" x:Name="InputTextBoxView">
    <Grid>
        <TextBox Height="auto" VerticalScrollBarVisibility="Auto" TextWrapping="{Binding ElementName=InputTextBoxView, Path=TextWrapping}" AcceptsReturn="{Binding ElementName=InputTextBoxView, Path=AcceptsReturn}" Text="{Binding ElementName=InputTextBoxView, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextChanged="InputTextChanged" x:Name="Input" Style="{StaticResource InputBox}"/>
        <TextBlock VerticalAlignment="Center" Foreground="Gray" Style="{StaticResource PlaceHolder}" x:Name="HolderText" IsHitTestVisible="False" Text="{Binding ElementName=InputTextBoxView, Path=Holder}"/>
    </Grid>
</UserControl>
