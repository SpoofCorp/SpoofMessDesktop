<UserControl x:Class="SpoofMess.ViewElements.InputTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" x:Name="InputTextBoxView">
    <Grid>
        <TextBlock 
            VerticalAlignment="Center" 
            Foreground="Gray" 
            Style="{StaticResource PlaceHolder}" 
            x:Name="HolderText" 
            IsHitTestVisible="False" 
            Text="{Binding ElementName=InputTextBoxView, Path=Holder}"
            Background="Transparent"/>
        <TextBox
                BorderBrush="Transparent"
                Height="auto"
                 Background="Transparent"
                 VerticalScrollBarVisibility="Auto" 
                 TextWrapping="{Binding ElementName=InputTextBoxView, Path=TextWrapping}" 
                 AcceptsReturn="{Binding ElementName=InputTextBoxView, Path=AcceptsReturn}" 
                 Text="{Binding ElementName=InputTextBoxView, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                 TextChanged="InputTextChanged" 
                 x:Name="Input" 
                 Style="{DynamicResource InputBox}">
            <TextBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Command="ApplicationCommands.Cut" Header="Вырезать"/>
                    <MenuItem Command="ApplicationCommands.Copy" Header="Копировать"/>
                    <MenuItem Command="ApplicationCommands.Paste" Header="Вставить"/>
                </ContextMenu>
            </TextBox.ContextMenu>
        </TextBox>
    </Grid>
</UserControl>
