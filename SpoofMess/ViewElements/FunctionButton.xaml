<UserControl x:Class="SpoofMess.ViewElements.FunctionButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SpoofMess.ViewElements"
             mc:Ignorable="d" 
             x:Name="FunctionalButtonView">
    <Button Style="{StaticResource BaseFunctionButton}" HorizontalContentAlignment="{Binding ElementName=FunctionalButtonView, Path=Alignment}" Padding="0" Command="{Binding ElementName=FunctionalButtonView, Path=Command}">
        <Button.Content>
            <DockPanel>
                <TextBlock Text="{Binding ElementName=FunctionalButtonView, Path=Icon}" DockPanel.Dock="Left"/>
                <TextBlock Text="{Binding ElementName=FunctionalButtonView, Path=Text}" DockPanel.Dock="Right"/>
            </DockPanel>
        </Button.Content>
    </Button>
</UserControl>
